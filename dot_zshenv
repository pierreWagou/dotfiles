# =============================================================================
# Zsh Environment - Bootstrap ZDOTDIR
# =============================================================================
# This file MUST remain at ~/.zshenv (it's read first, before ZDOTDIR is set)

# -----------------------------------------------------------------------------
# XDG Base Directory Specification
# -----------------------------------------------------------------------------
# Set Zsh configuration directory
export XDG_CONFIG_HOME="$HOME/.config"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# Set Docker configuration directory
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"

# Set FZF configuration file
export FZF_DEFAULT_OPTS_FILE="$XDG_CONFIG_HOME/fzf/config"

# Set Eza configuration directory
export EZA_CONFIG_DIR="$XDG_CONFIG_HOME/eza"

# Set Claude confiuration directory
export CLAUDE_CONFIG_DIR="$XDG_CONFIG_HOME/claude"

# Set Databricks configuration file
export DATABRICKS_CONFIG_FILE="$XDG_CONFIG_HOME/databricks/databrickscfg"

# Set GNUPG configuration directory
export GNUPGHOME="$XDG_CONFIG_HOME/gnupg"

# Set Starship confiuration file
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/starship.toml"

# -----------------------------------------------------------------------------
# Path Configuration
# -----------------------------------------------------------------------------
typeset -U path cdpath fpath manpath

# Pyenv
export PYENV_ROOT="$HOME/.local/share/pyenv"
[[ -d $PYENV_ROOT/bin ]] && path=("$PYENV_ROOT/bin" $path)

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
export GPG_TTY=$TTY
